#############################################
# PROVIDER
#############################################

provider "aws" {
  region = "us-west-2"
}

#############################################
# VARIÁVEL GLOBAL
#############################################

variable "project_name" {
  default = "Terraform-AppWeb"
}

#############################################
# VPC
#############################################

module "vpc" {
  source = "./modules/vpc"
}

#############################################
# S3
#############################################

module "s3" {
  source       = "./modules/s3"
  project_name = var.project_name
}

#############################################
# IAM
#############################################

module "iam" {
  source       = "./modules/iam"
  project_name = var.project_name
}